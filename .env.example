# Opriva — credenciales locales (NO subir .env a git)
# Copia este archivo como .env y llena los valores

# Número WhatsApp formato: código país + número sin espacios
# Panamá = 507 + 8 dígitos. Ejemplo: 50767891234
CALLMEBOT_PHONE=507XXXXXXXX

# API key que CallMeBot manda por WhatsApp al registrarte
# Guía: https://callmebot.com
CALLMEBOT_APIKEY=XXXXXXXX
